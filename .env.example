# === Cross-Model Activation Oracles — Environment Variables ===
# Copy this to .env and fill in your values:
#   cp .env.example .env

# HuggingFace (required for gated models like Gemma)
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Weights & Biases (optional, for experiment tracking)
WANDB_API_KEY=
WANDB_PROJECT=cross-model-activation-oracles
WANDB_ENTITY=

# OpenAI (optional, only if using GPT-based oracles for comparison)
OPENAI_API_KEY=

# Device config
CUDA_VISIBLE_DEVICES=0
